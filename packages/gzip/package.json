{
  "name": "@culvert/gzip",
  "version": "0.1.0",
  "description": "Streaming gzip compression and decompression. Platform-native DEFLATE. CRC-32 verified. Concatenated member support.",
  "type": "module",
  "main": "dist/index",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@culvert/stream": "*",
    "@culvert/crc32": "*",
    "@culvert/internal-deflate": "*"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "author": "Khalid Adan",
  "license": "MIT"
}
